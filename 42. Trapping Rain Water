class Solution {
public:
    int trap(vector<int>& height) {
        int n=height.size();
         vector<int>v(n);
         int max=height[0];
         v[0]=-1;
         for (int i=1;i<n;i++){
            v[i]=max;
            if(height[i]>max) max=height[i];           
         }
         vector<int>v1(n);
         int max1=height[n-1];
         v1[n-1]=-1;
         for(int i=n-2;i>=0;i--){
            v1[i]=max1;
            if(height[i]>max1) max1=height[i];
         }
         vector<int> mini(n);
         for(int i=0;i<n;i++){
            mini[i]=min(v[i],v1[i]);           
         }
         int sum=0;
         for(int i=1;i<n-1;i++){
            if(height[i]<mini[i]){
                sum+=(mini[i]-height[i]);
            }
         }    
        return sum;
    }
};